# Copy this to .env and fill in your values
# Then load with: export $(cat .env | xargs)

# === Required ===
GITHUB_TOKEN=ghp_your_token_here
ANTHROPIC_API_KEY=sk-ant-your_key_here

# === Notifications (at least one) ===
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
NOTIFY_EMAIL=you@gmail.com
GMAIL_APP_PASSWORD=your_app_password_here  # Not your login password — see README

# === Tuning ===
POLL_INTERVAL_MINUTES=15
MATCH_THRESHOLD=0.65       # 0.0–1.0, higher = fewer but better matches
MIN_SALARY_USD=0           # e.g. 100000 to skip anything below $100k

# === Phase 2: Auto-apply (leave false until you trust the agent) ===
AUTO_APPLY_ENABLED=false
RESUME_PATH=resume.pdf
