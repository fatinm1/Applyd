# Copy this to .env and fill in your values
# Then load with: export $(cat .env | xargs)

# === Required ===
GITHUB_TOKEN=ghp_your_token_here

# === Optional AI ===
# Default is free heuristics-only:
LLM_PROVIDER=none               # none | anthropic | ollama
LLM_MODEL=qwen2.5:14b           # used when LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TIMEOUT_SECONDS=60

# If you choose Anthropic:
ANTHROPIC_API_KEY=sk-ant-your_key_here

# === Notifications (at least one) ===
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
NOTIFY_EMAIL=you@gmail.com
GMAIL_APP_PASSWORD=your_app_password_here  # Not your login password — see README

# === Email approval requests (optional) ===
# Sends a per-job email with Approve/Reject links + attachments (resume PDF + cover letter).
EMAIL_APPROVAL_REQUESTS_ENABLED=false
PUBLIC_BASE_URL=https://your-domain.example   # must match your deployed site (used in email links)
MAIL_SIGNING_SECRET=change-me-long-random     # HMAC secret for one-click links (set in production!)
MAIL_ACTION_EXPIRY_HOURS=168

# === Tuning ===
POLL_INTERVAL_MINUTES=15
MATCH_THRESHOLD=0.65       # 0.0–1.0, higher = fewer but better matches
MIN_SALARY_USD=0           # e.g. 100000 to skip anything below $100k

# === Database (SQLite default) ===
# On Railway, you typically want MySQL + run a one-time migration from local `jobs.db`.
DB_BACKEND=sqlite
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=your_mysql_database

# === Phase 2: Auto-apply (leave false until you trust the agent) ===
AUTO_APPLY_ENABLED=false
RESUME_PATH=resume.pdf

# === Resume tailoring (job-specific PDFs) ===
# Requires LaTeX tooling on the machine (pdflatex).
TAILORED_RESUME_ENABLED=true
RESUME_TEX_PATH=resume/resume_template.tex
TAILORED_RESUME_DIR=tailored_resumes
RESUME_TEX_COMPILER=pdflatex
RESUME_TEX_PASSES=1

# === Web dashboard auth ===
# Protects auto-apply actions behind a login.
# On first startup with these set, a `users` row is created; digest/approval emails
# go to each user's "notification email" (editable under dashboard → profile) and
# also to NOTIFY_EMAIL when the worker runs for everyone.
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me
# Self-service sign-up at /register (recommended for personal or trusted deployments).
ALLOW_OPEN_REGISTRATION=true
# If ALLOW_OPEN_REGISTRATION is false, set a secret and require it as invite_code on /register.
REGISTRATION_INVITE_CODE=
SESSION_SECRET_KEY=dev-change-me
